[gd_scene load_steps=4 format=3 uid="uid://site_shell"]

[ext_resource type="Script" path="res://src/scenes/world/site_shell.gd" id="1_site"]
[ext_resource type="PackedScene" uid="uid://player" path="res://src/scenes/office/player.tscn" id="2_player"]
[ext_resource type="PackedScene" uid="uid://door_component" path="res://src/scenes/components/door.tscn" id="3_door"]
[ext_resource type="Script" path="res://src/scenes/components/spawn_point.gd" id="4_spawn"]

[node name="SiteShell" type="Node2D"]
script = ExtResource("1_site")

[node name="Floor" type="ColorRect" parent="."]
offset_right = 480.0
offset_bottom = 270.0
color = Color(0.16, 0.18, 0.22, 1)

[node name="Sign" type="Label" parent="."]
offset_left = 60.0
offset_top = 80.0
offset_right = 420.0
offset_bottom = 160.0
text = "[ FRAMEWORK PROOF ]
This is a stub site.
Real DarkLock content lands next.
Walk back through the door to return."
horizontal_alignment = 1

[node name="ExitDoor" parent="." instance=ExtResource("3_door")]
position = Vector2(240, 230)
target_location = &"street_downtown"
target_spawn = &"from_site"
prompt = "[E] Leave site"

[node name="DefaultSpawn" type="Marker2D" parent="."]
position = Vector2(240, 180)
script = ExtResource("4_spawn")
id = &"default"

[node name="Player" parent="." instance=ExtResource("2_player")]
position = Vector2(240, 180)
