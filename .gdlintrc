# gdlint configuration for DFIR Simulator.
# This file must be valid YAML (older := / = syntax did not parse under
# gdtoolkit 4.3+ and silently disabled the entire config).
#
# Line length is generous to accommodate embedded evidence/log strings
# inlined in GDScript source (case loaders, sample content). Code lines
# should still aim for ~100 chars.

max-line-length: 500
max-returns: 12
max-public-methods: 40

# Rules we deliberately relax for this codebase:
# - class-definitions-order: autoloads and data models freely mix
#   pubvars / signals / enums; enforcing the default order would require
#   a full restructure for no real benefit.
# - no-elif-return / no-else-return: we prefer explicit branches in
#   match-heavy dispatch code.
disable:
  - class-definitions-order
  - no-elif-return
  - no-else-return
