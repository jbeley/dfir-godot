class-definitions-order := ["tools", "classnames", "extends", "signals", "enums", "consts", "exports", "pubvars", "prvvars", "onreadypubvars", "onreadyprvvars", "others"]
function-name = "(_on_|_)[a-z][a-z0-9_]*"
class-name = "[A-Z][a-zA-Z0-9]*"
signal-name = "[a-z][a-z0-9_]*"
const-name = "[A-Z_][A-Z0-9_]*"
enum-name = "[A-Z][a-zA-Z0-9]*"
enum-element-name = "[A-Z_][A-Z0-9_]*"
max-line-length = 120
tab-characters = 1
max-file-lines = 500
