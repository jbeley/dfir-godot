; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="DFIR Simulator"
config/description="A DFIR consultant simulator. Investigate incidents. Analyze evidence. Write reports. Pet the cat."
run/main_scene="res://src/scenes/main_menu/main_menu.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://src/autoloads/game_manager.gd"
InputHelper="*res://src/autoloads/input_helper.gd"
TimeManager="*res://src/autoloads/time_manager.gd"
CaseManager="*res://src/autoloads/case_manager.gd"
ThreatIntelManager="*res://src/autoloads/threat_intel_manager.gd"
ReputationManager="*res://src/autoloads/reputation_manager.gd"
AudioManager="*res://src/autoloads/audio_manager.gd"
InterruptionManager="*res://src/systems/interruptions/interruption_manager.gd"
SfxBank="*res://src/autoloads/sfx_bank.gd"
CampaignManager="*res://src/systems/campaign/campaign_manager.gd"
TutorialManager="*res://src/systems/tutorial/tutorial_manager.gd"
TouchControls="*res://src/ui/components/touch_controls.tscn"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/window_width_override=1440
window/size/window_height_override=810
window/stretch/mode="viewport"
window/stretch/aspect="keep"
window/vsync/vsync_mode=1

